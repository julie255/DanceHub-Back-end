# Base de donnees
spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/NOM_DE_TA_BASE}
spring.datasource.username=${DB_USERNAME:TON_USERNAME}
spring.datasource.password=${DB_PASSWORD:TON_PASSWORD}
spring.datasource.driver-class-name=org.postgresql.Driver

# Hibernate
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.open-in-view=false
spring.sql.init.mode=never

# Port du serveur
server.port=8080

# JWT
jwt.secret=${JWT_SECRET:REMPLACE_PAR_UNE_CLE_DE_32_CARACTERES_MINIMUM}
jwt.expiration=${JWT_EXPIRATION:86400000}
